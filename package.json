{
  "name": "onyx-mcp",
  "version": "1.0.0",
  "description": "MCP server for Schwarz IT onyx design system (offline docs from export)",
  "type": "module",
  "bin": {
    "onyx-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node --import tsx src/cli.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "smoke": "node scripts/smoke-client.mjs",
    "eval:quality": "node scripts/eval-quality.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "onyx",
    "sit-onyx",
    "vue"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fuse.js": "^7.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
